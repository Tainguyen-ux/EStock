# EStock API Configuration
# Copy this file to .env and update values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS - comma separated origins, use * for all
CORS_ORIGINS=*

# Vnstock API Key (optional)
# Register free at https://vnstocks.com/login
# Tiers: guest (20 req/min), community (60 req/min), sponsor (180+ req/min)
VNSTOCK_API_KEY=

# Cache TTL in seconds
CACHE_TTL_QUOTE=30
CACHE_TTL_OHLCV=300
CACHE_TTL_REFERENCE=3600
CACHE_TTL_FUNDAMENTAL=3600
CACHE_TTL_RETAIL=600
